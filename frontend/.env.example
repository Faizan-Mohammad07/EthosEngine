# EthosEngine Frontend Environment Variables
# Copy this file to .env and update with your values

# API Configuration
# Backend API base URL (default: http://localhost:8000)
VITE_API_BASE_URL=http://localhost:8000

# Development Settings
# Enable debug logging (true/false)
VITE_DEBUG_MODE=false

# Feature Flags
# Enable mock data mode for development without backend (true/false)
VITE_USE_MOCK_DATA=false

# IBM Branding
VITE_APP_NAME=EthosEngine
VITE_APP_TAGLINE=AI Integrity Sentinel

# Analytics (optional)
# VITE_ANALYTICS_ID=your-analytics-id